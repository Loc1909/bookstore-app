<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.bookstore_app">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_bookstore_app"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_bookstore_app"
        android:supportsRtl="true"
        android:theme="@style/Theme.Bookstoreapp">

        <!-- Launcher -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Admin -->
        <activity android:name=".activities.AdminDashboardActivity" android:exported="false"/>
        <activity android:name=".activities.AdminBookActivity" android:exported="false"/>
        <activity android:name=".activities.AdminUserActivity" android:exported="false"/>
        <activity android:name=".activities.AdminCategoryActivity" android:exported="false"/>
        <activity android:name=".activities.StatsActivity" android:exported="false"/>

        <!-- Book -->
        <activity android:name=".activities.AddBookActivity" android:exported="false"/>
        <activity android:name=".activities.EditBookActivity" android:exported="false"/>

        <!-- Cart -->
        <activity android:name=".activities.CartActivity" android:exported="false"/>

        <activity android:name=".activities.BookDetailActivity" android:exported="false"/>



    </application>

</manifest>