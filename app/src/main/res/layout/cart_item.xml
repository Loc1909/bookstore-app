<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    android:backgroundTint="@color/cream_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <CheckBox
            android:id="@+id/cbSelected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/gold_primary" />

        <!-- IMAGE -->
        <ImageView
            android:id="@+id/imgBook"
            android:layout_width="90dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:background="@color/dark_espresso_border"
            android:clipToOutline="true"/>

        <!-- INFO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <!-- TITLE -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tên sách rất dài có thể xuống dòng"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/dark_espresso"
                android:maxLines="2"
                android:ellipsize="end"
                android:fontFamily="serif"/>

            <!-- PRICE -->
            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100.000đ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/gold_primary"
                android:layout_marginTop="6dp"/>

            <!-- QUANTITY -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SL:"
                    android:textSize="14sp"
                    android:textColor="@color/dark_espresso"
                    android:layout_marginEnd="8dp"/>

                <ImageView
                    android:id="@+id/btnMinus"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_minus"
                    android:padding="6dp"
                    android:background="@drawable/bg_circle"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/gold_primary"/>

                <TextView
                    android:id="@+id/tvQuantity"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="16sp"
                    android:textColor="@color/dark_espresso"
                    android:gravity="center"/>

                <ImageView
                    android:id="@+id/btnPlus"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_plus"
                    android:padding="6dp"
                    android:background="@drawable/bg_circle"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/gold_primary"/>
            </LinearLayout>
        </LinearLayout>

        <!-- DELETE -->
        <ImageView
            android:id="@+id/btnDelete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="top"
            android:padding="6dp"
            android:src="@drawable/delete_24px"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/gold_muted"/>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>