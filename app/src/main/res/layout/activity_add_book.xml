<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FA">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="#1A1A2E">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_icon_circle_dark"
                android:src="@drawable/arrow_back"
                android:tint="#B0FFFFFF"
                android:contentDescription="Back"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thêm sách mới"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- FORM CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <!-- IMAGE PICKER -->
                <FrameLayout
                    android:id="@+id/imgPickerArea"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:background="@drawable/bg_image_picker"
                    android:layout_marginBottom="20dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/imgBook"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/imgPlaceholder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_image_picker"
                            android:tint="#888780"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chọn ảnh bìa"
                            android:textSize="13sp"
                            android:textColor="#888780"/>
                    </LinearLayout>
                </FrameLayout>

                <!-- TITLE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIÊU ĐỀ"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#888780"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/edtTitle"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Nhập tiêu đề sách..."
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:textColorHint="#B4B2A9"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:singleLine="true"
                    android:layout_marginBottom="16dp"/>

                <!-- AUTHOR -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TÁC GIẢ"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#888780"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/edtAuthor"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Nhập tên tác giả..."
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:textColorHint="#B4B2A9"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:singleLine="true"
                    android:layout_marginBottom="16dp"/>

                <!-- CATEGORY -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DANH MỤC"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#888780"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>

                <Spinner
                    android:id="@+id/spinnerCategory"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_spinner_field"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="16dp"/>

                <!-- PRICE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GIÁ (₫)"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#888780"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/edtPrice"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="0"
                    android:inputType="numberDecimal"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:textColorHint="#B4B2A9"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="24dp"/>

                <!-- SAVE BUTTON -->
                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Lưu sách"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:backgroundTint="#1A1A2E"
                    style="@style/Widget.MaterialComponents.Button"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>