<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_card">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đánh giá sản phẩm"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="#1F1F1F"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <RatingBar
        android:id="@+id/ratingBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:numStars="5"
        android:stepSize="1"
        android:rating="0"
        android:progressTint="#FFB300"
        android:secondaryProgressTint="#FFB300"
        android:scaleX="1.1"
        android:scaleY="1.1"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nhận xét"
        android:textSize="14sp"
        android:textColor="#666"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/edtComment"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:gravity="top"
        android:padding="14dp"
        android:hint="Chia sẻ trải nghiệm của bạn..."
        android:background="@drawable/bg_edittext_round"
        android:textColor="#222"
        android:textColorHint="#999"
        android:inputType="textMultiLine"/>
</LinearLayout>