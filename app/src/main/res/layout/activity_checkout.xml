<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream">

    <!-- APP BAR -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dark_espresso"
        app:elevation="0dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <TextView
                android:text="Checkout"
                android:textColor="@color/gold_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:layout_marginBottom="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Xác nhận đơn hàng"
                android:textColor="@color/cream_light"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="90dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ADDRESS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/cream_light"
                app:strokeColor="@color/dark_espresso_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Thông tin giao hàng"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/dark_espresso"
                        android:layout_marginBottom="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Số điện thoại"
                        android:textSize="12sp"
                        android:textColor="@color/dark_espresso"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/edtPhone"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Nhập số điện thoại"
                        android:textColor="@color/dark_espresso"
                        android:paddingHorizontal="12dp"
                        android:background="@android:drawable/edit_text"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:text="Địa chỉ nhận hàng"
                        android:textSize="12sp"
                        android:textColor="@color/dark_espresso"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/edtAddress"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:textColor="@color/dark_espresso"
                        android:hint="Số nhà, đường, quận/huyện..."
                        android:paddingHorizontal="12dp"
                        android:background="@android:drawable/edit_text"/>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- PRODUCTS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/cream_light"
                app:strokeColor="@color/dark_espresso_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Sản phẩm"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/dark_espresso"
                        android:layout_marginBottom="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvCheckoutItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- SUMMARY -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                android:textColor="@color/dark_espresso"
                app:cardBackgroundColor="@color/cream_light"
                app:strokeColor="@color/dark_espresso_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Tổng kết đơn hàng"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/dark_espresso"
                        android:layout_marginBottom="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <!-- SUBTOTAL -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:textColor="@color/dark_espresso"
                            android:text="Tiền hàng"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:textColor="@color/dark_espresso"
                            android:id="@+id/tvSubtotal"
                            android:text="0đ"
                            android:layout_alignParentEnd="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </RelativeLayout>

                    <!-- SHIPPING -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:text="Phí vận chuyển"
                            android:textColor="@color/dark_espresso"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="30.000đ"
                            android:textColor="@color/dark_espresso"
                            android:layout_alignParentEnd="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/dark_espresso_border"/>

                    <!-- TOTAL -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:text="Tổng thanh toán"
                            android:textStyle="bold"
                            android:textColor="@color/dark_espresso"
                            android:textSize="18sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/tvCheckoutTotal"
                            android:text="0đ"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="@color/gold_primary"
                            android:layout_alignParentEnd="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </RelativeLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FIXED BOTTOM BUTTON -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardBackgroundColor="@color/dark_espresso"
        app:cardElevation="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmOrder"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_margin="16dp"
            android:text="Xác nhận đặt hàng"
            android:textAllCaps="false"
            android:textColor="@color/dark_espresso"
            app:backgroundTint="@color/gold_primary"
            app:cornerRadius="14dp"/>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>